      "fontSize": 14,
      "fontFamily": 1,
      "text": "1. setup-plan.sh -> plan.md template\n2. Reads constitution + .claude/skills/*.md\n3. Phase 0: Research agents -> research.md\n4. Phase 1: data-model.md, contracts/, quickstart.md\n5. update-agent-context.sh\n6. Suggests /diagram.mermaid or /diagram.excalidraw",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. setup-plan.sh -> plan.md template\n2. Reads constitution + .claude/skills/*.md\n3. Phase 0: Research agents -> research.md\n4. Phase 1: data-model.md, contracts/, quickstart.md\n5. update-agent-context.sh\n6. Suggests /diagram.mermaid or /diagram.excalidraw",
      "autoResize": true,
      "lineHeight": 1.25
