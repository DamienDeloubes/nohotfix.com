      "link": null,
      "locked": false,
      "fontSize": 14,
      "fontFamily": 1,
      "text": "1. create-new-feature.sh -> git branch + specs dir\n2. Reads spec-template.md\n3. Fills spec from feature description\n4. Writes spec.md + checklists/requirements.md\n5. Self-validates quality (max 3 iterations)",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. create-new-feature.sh -> git branch + specs dir\n2. Reads spec-template.md\n3. Fills spec from feature description\n4. Writes spec.md + checklists/requirements.md\n5. Self-validates quality (max 3 iterations)",
      "autoResize": true,
      "lineHeight": 1.25
    },
