{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests",
    "db:migrate": "tsx src/migrate.ts",
    "format": "prettier --write . --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/otel": "^0.17.1",
    "@fastify/sensible": "^6.0.4",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.55.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
    "@opentelemetry/sdk-metrics": "^1.28.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "@nohotfix/db": "workspace:*",
    "@nohotfix/domain-audit": "workspace:*",
    "@nohotfix/domain-authoring": "workspace:*",
    "@nohotfix/domain-billing": "workspace:*",
    "@nohotfix/domain-execution": "workspace:*",
    "@nohotfix/domain-identity": "workspace:*",
    "@nohotfix/email": "workspace:*",
    "@nohotfix/shared": "workspace:*",
    "@sentry/node": "^8.0.0",
    "@workos-inc/node": "^7.0.0",
    "fastify": "^5.1.0",
    "fastify-plugin": "^4.5.1",
    "jose": "^4.15.9",
    "kysely": "^0.27.4",
    "pino": "^9.5.0",
    "stripe": "^17.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nohotfix/eslint-config": "workspace:*",
    "@nohotfix/prettier-config": "workspace:*",
    "@nohotfix/typescript-config": "workspace:*",
    "@types/node": "^22.10.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
