# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ────────────────────────────────────────────────────────────────
# DigitalOcean Managed PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/nohotfix

# ── WorkOS ──────────────────────────────────────────────────────────────────
# WorkOS OAuth client ID (from WorkOS dashboard)
WORKOS_CLIENT_ID=client_XXXXXXXXXXXXXXXXXXXX

# WorkOS API secret key
WORKOS_API_KEY=sk_XXXXXXXXXXXXXXXXXXXX

# WorkOS OAuth redirect URI — must match exactly what's configured in the WorkOS dashboard
# Production: https://api.nohotfix.com/auth/callback
WORKOS_REDIRECT_URI=http://localhost:3001/auth/callback

# ── Auth ────────────────────────────────────────────────────────────────────
# URL of apps/app — used for post-auth redirect after OAuth callback
# Production: https://app.nohotfix.com
APP_URL=http://localhost:5173

# Secret to sign the refresh token cookie (min 32 chars)
COOKIE_SECRET=change-me-to-a-random-32-char-string!!

# ── Stripe ───────────────────────────────────────────────────────────────────
# Stripe secret key (from Stripe dashboard → Developers → API keys)
# STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXX

# Stripe webhook signing secret (from Stripe dashboard → Webhooks)
# STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX

# ── Resend ───────────────────────────────────────────────────────────────────
# Resend API key for transactional email
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX

# ── Web App URL ───────────────────────────────────────────────────────────────
# URL of apps/web — used for invite link construction
# Production: https://nohotfix.com
WEB_URL=http://localhost:3000

# ── DigitalOcean Spaces ──────────────────────────────────────────────────────
# DO_SPACES_KEY=XXXXXXXXXXXXXXXXXXXX
# DO_SPACES_SECRET=XXXXXXXXXXXXXXXXXXXX
# DO_SPACES_BUCKET=nohotfix-artifacts
# DO_SPACES_REGION=fra1
# DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com

# ── Observability (optional) ────────────────────────────────────────────────
# Sentry DSN — omit to disable error reporting
# SENTRY_DSN=https://XXXXXXXXXXXXXXXXXXXX@sentry.io/0000000

# OTLP HTTP endpoint — omit to disable telemetry in local dev
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
