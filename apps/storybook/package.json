    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@nohotfix/eslint-config": "workspace:*",
    "@nohotfix/prettier-config": "workspace:*",
    "@nohotfix/typescript-config": "workspace:*",
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/blocks": "^8.6.12",
    "@storybook/react": "^8.6.12",
    "@storybook/react-vite": "^8.6.12",
    "storybook": "^8.6.12",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.3.4",
