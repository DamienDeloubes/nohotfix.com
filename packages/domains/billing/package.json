{
  "name": "@nohotfix/domain-billing",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "default": "./dist/ui/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write . --ignore-path ../../../.prettierignore"
  },
  "dependencies": {
    "@nohotfix/shared": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nohotfix/eslint-config": "workspace:*",
    "@nohotfix/prettier-config": "workspace:*",
    "@nohotfix/typescript-config": "workspace:*",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "@tanstack/react-query": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    }
  }
}
