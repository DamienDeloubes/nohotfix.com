{
  "name": "@nohotfix/shared",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write . --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nohotfix/eslint-config": "workspace:*",
    "@nohotfix/prettier-config": "workspace:*",
    "@nohotfix/typescript-config": "workspace:*",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
