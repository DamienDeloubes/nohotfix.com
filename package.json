{
  "name": "nohotfix",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=api --filter=web --filter=app --ui=tui",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:setup": "turbo run db:setup",
    "db:migrate": "turbo run db:migrate",
    "format": "turbo run format",
    "kill:ports": "npx kill-port 5432"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "@nohotfix/prettier-config": "workspace:*",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1"
  }
}
