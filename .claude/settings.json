{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "Bash(pnpm turbo run *)",
      "Bash(pnpm --filter * test)",
      "Bash(pnpm --filter * build)",
      "Bash(pnpm --filter * typecheck)",
      "Bash(pnpm --filter * lint)",
      "Bash(pnpm --filter * format)",
      "Bash(pnpm --filter * dev)",
      "Bash(pnpm --filter * db:migrate)",
      "Bash(pnpm install *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git stash *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(gh *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(docker compose up *)",
      "Bash(docker compose ps *)",
      "Bash(docker compose logs *)",
      "Bash(npx tsc --noEmit *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(pnpm publish *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(docker compose down -v *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(echo \"$CLAUDE_TOOL_INPUT\" | jq -r '.file_path // empty') && if echo \"$file\" | grep -q 'routeTree.gen.ts$'; then echo 'BLOCK: routeTree.gen.ts is auto-generated by TanStack Router. Never edit it manually.' && exit 1; fi"
          }
        ]
      }
    ]
  }
}
